{
  "name": "claude-code-account-switcher",
  "displayName": "Claude Multi-Account Switcher",
  "description": "Quickly switch between Claude accounts (subscriptions) in Claude Code, with live usage limits.",
  "version": "0.2.2",
  "publisher": "KrzysztofZander",
  "author": {
    "name": "Krzysztof Zander",
    "email": "krzysztof.zander@retencja.pl"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "anthropic",
    "account",
    "switcher",
    "usage",
    "limits"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1f1f1f",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KrzysztofZander/claude-account-switcher"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeSwitcher",
          "title": "Claude Accounts",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudeSwitcher": [
        {
          "id": "claudeSwitcher.accountsView",
          "name": "Accounts",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeSwitcher.addCurrentAccount",
        "title": "Claude: Save current account as profile",
        "icon": "$(add)"
      },
      {
        "command": "claudeSwitcher.switchAccount",
        "title": "Claude: Switch account",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "claudeSwitcher.refreshUsage",
        "title": "Claude: Refresh usage limits",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeSwitcher.sayHi",
        "title": "Claude: Say Hi on account",
        "icon": "$(comment)"
      },
      {
        "command": "claudeSwitcher.openIndependentWindow",
        "title": "Claude: Open independent account window",
        "icon": "$(window)"
      },
      {
        "command": "claudeSwitcher.login",
        "title": "Claude: Log in from terminal",
        "icon": "$(sign-in)"
      },
      {
        "command": "claudeSwitcher.reauthorizeProfile",
        "title": "Claude: Reauthorize account profile",
        "icon": "$(sign-in)"
      },
      {
        "command": "claudeSwitcher.completeProfileReauthorization",
        "title": "Claude: Complete profile reauthorization",
        "icon": "$(pass)"
      },
      {
        "command": "claudeSwitcher.removeAccount",
        "title": "Claude: Remove account profile"
      },
      {
        "command": "claudeSwitcher.renameAccount",
        "title": "Claude: Rename account profile"
      },
      {
        "command": "claudeSwitcher.undoSwitch",
        "title": "Claude: Undo last switch"
      },
      {
        "command": "claudeSwitcher.openPanel",
        "title": "Claude: Show accounts panel"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeSwitcher.addCurrentAccount",
          "when": "view == claudeSwitcher.accountsView",
          "group": "navigation@1"
        },
        {
          "command": "claudeSwitcher.refreshUsage",
          "when": "view == claudeSwitcher.accountsView",
          "group": "navigation@2"
        },
        {
          "command": "claudeSwitcher.sayHi",
          "when": "view == claudeSwitcher.accountsView",
          "group": "navigation@3"
        },
        {
          "command": "claudeSwitcher.openIndependentWindow",
          "when": "view == claudeSwitcher.accountsView",
          "group": "navigation@4"
        },
        {
          "command": "claudeSwitcher.login",
          "when": "view == claudeSwitcher.accountsView",
          "group": "navigation@5"
        },
        {
          "command": "claudeSwitcher.reauthorizeProfile",
          "when": "view == claudeSwitcher.accountsView",
          "group": "navigation@6"
        }
      ],
      "commandPalette": [
        {
          "command": "claudeSwitcher.removeAccount"
        },
        {
          "command": "claudeSwitcher.renameAccount"
        }
      ]
    },
    "configuration": {
      "title": "Claude Account Switcher",
      "properties": {
        "claudeSwitcher.pollIntervalSeconds": {
          "type": "number",
          "default": 240,
          "minimum": 180,
          "markdownDescription": "How often (in seconds) to automatically refresh usage limits for each account. The endpoint is heavily rate-limited — values below 180s are raised to 180s."
        },
        "claudeSwitcher.autoReloadAfterSwitch": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Automatically reload the VS Code window after switching accounts (required for Claude Code to pick up the new account). When disabled, the extension asks first."
        },
        "claudeSwitcher.credentialsPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the Claude Code `.credentials.json` file. Empty = default `~/.claude/.credentials.json`."
        },
        "claudeSwitcher.warnThresholdPercent": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "markdownDescription": "Usage threshold (%) above which the limit bar turns red."
        },
        "claudeSwitcher.claudeCommand": {
          "type": "string",
          "default": "claude",
          "markdownDescription": "Claude Code CLI command used for login and Say Hi warmups. Use the full path to `claude.cmd`/`claude.exe` if VS Code cannot find `claude` in PATH."
        },
        "claudeSwitcher.sayHiModel": {
          "type": "string",
          "default": "haiku",
          "markdownDescription": "Model passed to `claude -p` for Say Hi warmups. `haiku` is the low-cost/default warmup choice."
        },
        "claudeSwitcher.sayHiPrompt": {
          "type": "string",
          "default": "Hi",
          "markdownDescription": "Prompt used by Say Hi warmups."
        },
        "claudeSwitcher.sayHiTimeoutSeconds": {
          "type": "number",
          "default": 120,
          "minimum": 15,
          "markdownDescription": "Maximum time to wait for a Say Hi warmup command."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "typecheck": "tsc --noEmit",
    "test:smoke": "node test/run-smoke.cjs",
    "build:vsix": "npm run package && vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
