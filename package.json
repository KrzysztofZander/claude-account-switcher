{
  "name": "claude-code-account-switcher",
  "displayName": "Claude Multi-Account Switcher",
  "description": "Quickly switch between Claude accounts (subscriptions) in Claude Code, with live usage limits.",
  "version": "0.1.0",
  "publisher": "KrzysztofZander",
  "author": {
    "name": "Krzysztof Zander",
    "email": "krzysztof.zander@retencja.pl"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "anthropic",
    "account",
    "switcher",
    "usage",
    "limits"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1f1f1f",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KrzysztofZander/claude-account-switcher"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeSwitcher",
          "title": "Claude Accounts",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudeSwitcher": [
        {
          "id": "claudeSwitcher.accountsView",
          "name": "Accounts",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeSwitcher.addCurrentAccount",
        "title": "Claude: Save current account as profile",
        "icon": "$(add)"
      },
      {
        "command": "claudeSwitcher.switchAccount",
        "title": "Claude: Switch account",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "claudeSwitcher.refreshUsage",
        "title": "Claude: Refresh usage limits",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeSwitcher.removeAccount",
        "title": "Claude: Remove account profile"
      },
      {
        "command": "claudeSwitcher.renameAccount",
        "title": "Claude: Rename account profile"
      },
      {
        "command": "claudeSwitcher.undoSwitch",
        "title": "Claude: Undo last switch"
      },
      {
        "command": "claudeSwitcher.openPanel",
        "title": "Claude: Show accounts panel"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeSwitcher.addCurrentAccount",
          "when": "view == claudeSwitcher.accountsView",
          "group": "navigation@1"
        },
        {
          "command": "claudeSwitcher.refreshUsage",
          "when": "view == claudeSwitcher.accountsView",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "claudeSwitcher.removeAccount"
        },
        {
          "command": "claudeSwitcher.renameAccount"
        }
      ]
    },
    "configuration": {
      "title": "Claude Account Switcher",
      "properties": {
        "claudeSwitcher.pollIntervalSeconds": {
          "type": "number",
          "default": 240,
          "minimum": 180,
          "markdownDescription": "How often (in seconds) to automatically refresh usage limits for each account. The endpoint is heavily rate-limited — values below 180s are raised to 180s."
        },
        "claudeSwitcher.autoReloadAfterSwitch": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Automatically reload the VS Code window after switching accounts (required for Claude Code to pick up the new account). When disabled, the extension asks first."
        },
        "claudeSwitcher.credentialsPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the Claude Code `.credentials.json` file. Empty = default `~/.claude/.credentials.json`."
        },
        "claudeSwitcher.warnThresholdPercent": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "maximum": 100,
          "markdownDescription": "Usage threshold (%) above which the limit bar turns red."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "typecheck": "tsc --noEmit",
    "test:smoke": "esbuild test/smoke.ts --bundle --platform=node --format=cjs --alias:vscode=./test/vscode-stub.js --outfile=out/smoke.cjs && node out/smoke.cjs",
    "build:vsix": "npm run package && vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}